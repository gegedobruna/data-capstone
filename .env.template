# ── Databricks connection ─────────────────────────────────────────────────────
# Inside a Databricks App, HOST and TOKEN are injected automatically.
# Only needed when running locally.
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<generate from: Settings → Developer → Access tokens>

# ── Gold catalog / schema ─────────────────────────────────────────────────────
# Do not change — confirmed from real workspace.
GOLD_CATALOG=dbx_metadata_governance_dev
GOLD_SCHEMA=gold

# ── SQL Warehouse ─────────────────────────────────────────────────────────────
# Databricks → SQL Warehouses → Serverless Starter Warehouse
# → copy ID from URL: .../sql/warehouses/<THIS_VALUE>
SQL_WAREHOUSE_ID=<your-serverless-warehouse-id>

# ── Genie space ───────────────────────────────────────────────────────────────
# Databricks → Genie → open governance space
# → copy ID from URL: .../genie/rooms/<THIS_VALUE>
GENIE_SPACE_ID=<your-genie-space-id>

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Databricks → Dashboards → open dashboard → copy URL
DASHBOARD_URL=<your-dashboard-embed-url>

# ── Alert thresholds ──────────────────────────────────────────────────────────
ALERT_DQ_THRESHOLD=5        # fires if dq_failed_rows/total > 5%
ALERT_QUARANTINE_MAX=50     # fires if dq_failed_rows > 50
